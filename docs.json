{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dataleap Docs",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "colors": {
    "primary": "#6176F3",
    "light": "#A5B4FC",
    "dark": "#444FE7"
  },
  "fonts": {
    "heading": {
      "family": "Inter Tight"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Introduction",
        "pages": [
          "index",
          "introduction/overview",
          "introduction/what-is-dataleap",
          "introduction/getting-started"
        ]
      },
      {
        "group": "Build your own agent",
        "pages": [
          "build/overview",
          "build/your-first-agent",
          "build/shape-agent-behavior",
          "build/connect-your-tools",
          "build/add-knowledge",
          "build/triggers",
          "build/versioning"
        ]
      },
      {
        "group": "Scale your craft",
        "pages": [
          "scale/overview",
          "scale/sub-agents-and-intelligence-levels",
          "scale/skills",
          "scale/programmatic-tool-calling"
        ]
      },
      {
        "group": "Sharing is Caring",
        "pages": [
          "share/overview",
          "share/team-spaces",
          "share/templates",
          "share/locked-templates",
          "share/when-to-share-what"
        ]
      },
      {
        "group": "Admin",
        "pages": [
          "admin/overview",
          "admin/users-and-roles",
          "admin/credits-and-usage",
          "admin/connected-apps-management"
        ]
      },
      {
        "group": "Video Series",
        "pages": [
          "video-series/overview",
          "video-series/section-1",
          "video-series/section-2",
          "video-series/section-3",
          "video-series/section-4"
        ]
      },
      {
        "group": "FAQ",
        "pages": [
          "faq"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://dataleap.ai",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://dataleap.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.dataleap.ai"
    }
  },
  "redirects": [
    { "source": "/getting-started", "destination": "/introduction/getting-started" },
    { "source": "/create-your-first-agent", "destination": "/build/your-first-agent" },
    { "source": "/shape-agent-behavior", "destination": "/build/shape-agent-behavior" },
    { "source": "/connect-apps", "destination": "/build/connect-your-tools" },
    { "source": "/add-knowledge", "destination": "/build/add-knowledge" },
    { "source": "/use-templates", "destination": "/share/templates" },
    { "source": "/usage-and-runs", "destination": "/admin/credits-and-usage" }
  ],
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {}
}
