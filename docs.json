{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dataleap Docs",
  "colors": {
    "primary": "#6176F3",
    "light": "#A5B4FC",
    "dark": "#444FE7"
  },
  "fonts": {
    "heading": {
      "family": "Inter Tight"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "getting-started",
          "create-your-first-agent"
        ]
      },
      {
        "group": "Build agents",
        "pages": [
          "shape-agent-behavior",
          "connect-apps",
          "add-knowledge",
          "use-templates"
        ]
      },
      {
        "group": "Operate agents",
        "pages": [
          "usage-and-runs"
        ]
      },
      {
        "group": "Video Series",
        "pages": [
          "video-series/overview",
          "video-series/section-1",
          "video-series/section-2",
          "video-series/section-3",
          "video-series/section-4"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://dataleap.ai",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://dataleap.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.dataleap.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {}
}
