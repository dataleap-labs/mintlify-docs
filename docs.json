{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Dataleap Docs",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#6D28D9"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "getting-started",
          "create-your-first-agent"
        ]
      },
      {
        "group": "Build agents",
        "pages": [
          "shape-agent-behavior",
          "connect-apps",
          "add-knowledge",
          "use-templates"
        ]
      },
      {
        "group": "Operate agents",
        "pages": [
          "usage-and-runs"
        ]
      }
